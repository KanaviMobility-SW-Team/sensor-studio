[[instances]]
instance_id = "instance-1"

[instances.engine]
id = "lidar-engine"
library_path = "engines/libexternal_lidar_engine.so"
config_path = "engines/external_lidar_engine.toml"

[instances.engine.settings]
profile = "default"
model = "sample_lidar"

[instances.transport]
type = "udp"
bind_addr = "0.0.0.0:5000"
buffer_size = 4096
multicast_addr = "224.0.0.5"
join_all_interfaces = true
interface_addrs = []

[instances.channel]
channel_id = 1
source_id = "sample_sensor"
topic = "/pointcloud/sample_sensor"
schema = "point_cloud"
encoder = "json"